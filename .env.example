# Dispatch — environment variable reference (AUTH-001)
#
# Copy this file to .env and adjust values for local development.
# Never commit a real .env file — only .env.example is tracked.

# ── PostgreSQL (db service — internal to the Docker network only) ────────────
POSTGRES_DB=dispatch
POSTGRES_USER=dispatch_user
POSTGRES_PASSWORD=CHANGE_ME_LOCAL_DEV_ONLY

# ── apps/api database connection (DEV-FOUNDATION-002) ────────────────────────
# docker-compose.yml derives this automatically for the `api` service from
# the POSTGRES_* values above, using the internal Docker network hostname
# `db` (PostgreSQL has no host port mapping — it is never reachable at
# localhost:5432 from the macOS host). This line documents the shape only;
# no code reads DATABASE_URL directly from this file.
#   DATABASE_URL=postgresql://dispatch_user:CHANGE_ME_LOCAL_DEV_ONLY@db:5432/dispatch?schema=public
#
# Migration and seed are separate operations, both run inside the Docker
# network (never against a host-exposed port — see scripts/db-verify.sh):
#   docker compose exec api npx prisma migrate deploy   # applies committed migrations
#   docker compose exec api npx prisma db seed          # idempotent system-role seed
# `prisma migrate dev` and `prisma migrate reset` are never used against this
# database — see CLAUDE.md §11 and scripts/db-verify.sh.

# ── Admin Web / Mobile PWA ────────────────────────────────────────────────────
# Backend base URL used by both frontends to build the health-check link and,
# in future milestones, API requests. Baked into the browser bundle at build
# time for NEXT_PUBLIC_* variables.
NEXT_PUBLIC_API_URL=http://localhost:6002

# ── Authentication (AUTH-001) ─────────────────────────────────────────────────
# JWT_ACCESS_SECRET is the only mandatory value below — the API fails to
# start without it (no weak production fallback). Generate a high-entropy
# local value and never commit it:
#   openssl rand -base64 48
# All other AUTH_*/JWT_* values below have safe defaults in code
# (apps/api/src/auth/config/auth.config.ts) and only need to be set here to
# override those defaults.
JWT_ACCESS_SECRET=CHANGE_ME_LOCAL_DEV_ONLY_GENERATE_WITH_OPENSSL_RAND
JWT_ACCESS_TTL_SECONDS=900
JWT_ISSUER=dispatch-api
JWT_AUDIENCE=dispatch-clients
AUTH_REFRESH_TTL_SECONDS=1209600
AUTH_SESSION_ABSOLUTE_TTL_SECONDS=2592000
AUTH_COOKIE_NAME=dispatch_refresh_token
# Secure=false only for explicit localhost/local-Docker development. Must be
# true wherever the API is served over HTTPS.
AUTH_COOKIE_SECURE=false
# Exact-origin allow-list for credentialed CORS — comma-separated, no
# wildcard. Must match the real Admin Web / Mobile PWA origins.
AUTH_ALLOWED_ORIGINS=http://localhost:6001,http://localhost:6003
# Format: <limit>:<ttlSeconds>
AUTH_LOGIN_RATE_LIMIT=5:60
AUTH_REFRESH_RATE_LIMIT=30:60
#
# Architecture notes:
#   - short-lived JWT access token, held in client memory only
#   - rotating opaque refresh token, delivered only via an HttpOnly cookie
#   - server-side AuthSession/RefreshTokenRecord tables provide immediate
#     revocation and reuse detection
#   - tokens are never stored in localStorage/sessionStorage/IndexedDB on
#     any client
#   - the initial SUPER_ADMIN is created only via the operator-only CLI
#     (npm run auth:bootstrap-super-admin --workspace=apps/api), never
#     automatically
