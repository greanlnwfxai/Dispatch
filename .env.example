# Dispatch — environment variable reference (DEV-FOUNDATION-001)
#
# Copy this file to .env and adjust values for local development.
# Never commit a real .env file — only .env.example is tracked.
#
# NOTE: apps/api does not yet connect to PostgreSQL (no Prisma schema is
# introduced in DEV-FOUNDATION-001 — see docs/CTO_SUMMARY_DEV_FOUNDATION_001.md).
# The db service below is provisioned so DEV-FOUNDATION-002 can start
# migrations against a running database without re-touching Docker Compose.

# ── PostgreSQL (db service — internal to the Docker network only) ────────────
POSTGRES_DB=dispatch
POSTGRES_USER=dispatch_user
POSTGRES_PASSWORD=CHANGE_ME_LOCAL_DEV_ONLY

# ── Admin Web / Mobile PWA ────────────────────────────────────────────────────
# Backend base URL used by both frontends to build the health-check link and,
# in future milestones, API requests. Baked into the browser bundle at build
# time for NEXT_PUBLIC_* variables.
NEXT_PUBLIC_API_URL=http://localhost:6002

# ── Future authentication boundary (AUTH-001 — NOT implemented yet) ──────────
# Recorded here only so the shape is documented ahead of time. No code in
# this repository reads these variables yet, and no auth endpoints exist.
#   - short-lived JWT access token
#   - rotating refresh token
#   - server-side session/revocation store
#   - tokens are never stored in localStorage on any client
