// Dispatch — Identity/Role technical persistence foundation
// (DEV-FOUNDATION-002), extended with Authentication/Session persistence
// (AUTH-001).
//
// Scope boundary (see CLAUDE.md, Dispatch Knowledge Topic 11 §7.1/7.2/§10):
//   - No default User is ever seeded here.
//   - Exactly the six approved application roles (Topic 03 §4, Topic 11
//     §7.2) are seeded by prisma/seed.ts — SUPER_ADMIN, ADMIN, DISPATCHER,
//     STOCK, INTERNAL_DELIVERY_EMPLOYEE, MANAGEMENT_AUDITOR.
//   - UserRoleAssignment is intentionally cardinality-neutral: Dispatch
//     Knowledge does not state whether a user may hold more than one role
//     at a time, so this schema does not enforce single-role or
//     multi-role policy — AUTH-001 authorization resolves roles per-user
//     without assuming exactly one.
//   - `loginId` is a neutral technical identifier (AUTH-001) — not typed,
//     validated, or named as an email or employee number. Only the
//     normalized form needed for unique login matching is stored.
//   - No plaintext password, refresh token, access token, or JWT secret is
//     ever persisted — only an Argon2id password hash and a SHA-256 hash of
//     the opaque refresh-token secret.
//   - AuthSession / RefreshTokenRecord provide server-side session and
//     revocation state so role/account-status changes and explicit
//     revocation take effect immediately, without waiting for a refresh
//     token to expire.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid()) @db.Uuid
  displayName String   @map("display_name") @db.VarChar(255)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // ── AUTH-001 credential fields — nullable/off by default so existing and
  // future technical identities may exist without credentials. `loginId` is
  // never stored as email/employee-number; only the normalized form needed
  // for unique login matching is kept. No plaintext password, ever.
  loginIdNormalized    String?   @map("login_id_normalized") @db.VarChar(320)
  passwordHash         String?   @map("password_hash") @db.VarChar(255)
  credentialsEnabled   Boolean   @default(false) @map("credentials_enabled")
  credentialsUpdatedAt DateTime? @map("credentials_updated_at") @db.Timestamptz(6)

  roleAssignments UserRoleAssignment[]
  authSessions    AuthSession[]

  // ── MVP-02 back-relations. Restrict (never Cascade) on every FK pointing
  // at User below preserves Customer Master search evidence, Task creator
  // attribution, and append-only Task status history even if a User row is
  // ever deactivated — see CLAUDE.md §20 (append-only history).
  customerMasterSearches CustomerMasterSearch[]
  createdDeliveryTasks   DeliveryTask[]         @relation("DeliveryTaskCreatedBy")
  updatedDeliveryTasks   DeliveryTask[]         @relation("DeliveryTaskUpdatedBy")
  taskEvents             TaskEvent[]
  preparationStarts      PreparationRecord[]           @relation("PreparationStartedBy")
  preparationReadyConfirms PreparationRecord[]         @relation("PreparationReadyConfirmedBy")
  preparationIssuesReported PreparationIssue[]         @relation("PreparationIssueReportedBy")
  preparationIssuesResolved PreparationIssue[]         @relation("PreparationIssueResolvedBy")
  preparationEvidenceUploads PreparationEvidence[]
  preparationDiscrepancyReports PreparationDiscrepancyReport[]
  preparationCorrectionsCreated PreparationCorrectionRecord[] @relation("PreparationCorrectionCreatedBy")
  preparationCorrectionsReviewed PreparationCorrectionRecord[] @relation("PreparationCorrectionReviewedBy")

  // ── MVP-04 back-relations. Restrict on every FK below preserves
  // append-only assignment history even if a User row is ever deactivated.
  taskAssignmentsAsPrimary TaskAssignment[]        @relation("TaskAssignmentPrimary")
  taskAssignmentsAsActor   TaskAssignment[]        @relation("TaskAssignmentActor")
  taskAssignmentSupports   TaskAssignmentSupport[]
  currentTaskAssignments   TaskCurrentAssignment[] @relation("TaskCurrentAssignmentPrimary")

  @@unique([loginIdNormalized])
  @@map("users")
}

// Server-side session record (AUTH-001). A session is the unit of
// revocation: revoking it immediately invalidates every refresh token
// chained to it, regardless of JWT access-token expiry. `expiresAt` is the
// absolute upper bound a rotated refresh token's own expiry may never
// exceed (Topic 11 §10 / CLAUDE.md AUTH-001 boundary). onDelete: Restrict
// on the User relation prevents a cascade from silently destroying session
// history.
model AuthSession {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastSeenAt    DateTime? @map("last_seen_at") @db.Timestamptz(6)
  expiresAt     DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt     DateTime? @map("revoked_at") @db.Timestamptz(6)
  revokedReason String?   @map("revoked_reason") @db.VarChar(64)

  user          User                 @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  refreshTokens RefreshTokenRecord[]

  @@index([userId])
  @@index([userId, revokedAt, expiresAt])
  @@map("auth_sessions")
}

// Opaque rotating refresh token record (AUTH-001). Only a cryptographic
// hash of the token's random secret is stored — never the raw token. Each
// successful refresh marks the current row `usedAt` and links it to its
// replacement via `replacedByTokenId`, so a used or revoked row can never
// authorize another rotation; reuse of either is treated as compromise and
// revokes the owning AuthSession (see AuthService).
model RefreshTokenRecord {
  id                String    @id @default(uuid()) @db.Uuid
  sessionId         String    @map("session_id") @db.Uuid
  tokenHash         String    @unique @map("token_hash") @db.VarChar(128)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt         DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt            DateTime? @map("used_at") @db.Timestamptz(6)
  revokedAt         DateTime? @map("revoked_at") @db.Timestamptz(6)
  replacedByTokenId String?   @unique @map("replaced_by_token_id") @db.Uuid

  session         AuthSession         @relation(fields: [sessionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  replacedByToken RefreshTokenRecord? @relation("TokenReplacement", fields: [replacedByTokenId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  replacesToken   RefreshTokenRecord? @relation("TokenReplacement")

  @@index([sessionId])
  @@map("refresh_token_records")
}

model Role {
  id           String   @id @default(uuid()) @db.Uuid
  code         String   @unique @db.VarChar(64)
  displayName  String   @map("display_name") @db.VarChar(255)
  isSystemRole Boolean  @default(true) @map("is_system_role")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  userAssignments UserRoleAssignment[]

  @@map("roles")
}

// Preserves role-assignment history (append-only in spirit): a row is never
// mutated to change which user/role it links, only created. onDelete:
// Restrict prevents deleting a User or Role that still has assignments,
// so history is never silently destroyed by a cascade.
model UserRoleAssignment {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_role_assignments")
}

// ═══════════════════════════════════════════════════════════════════════
// MVP-02 — Customer and Task Creation
// ═══════════════════════════════════════════════════════════════════════
//
// Traceability: BDR-CUSTOMER-001 (Option C, approved 2026-07-20),
// BDR-CUSTOMER-002 (Option B, approved 2026-07-20), BR-TASK-003 through
// BR-TASK-010, BR-DATA-003, VR-TASK-001a (Dispatch Knowledge Topic 06 §11).
//
// BDR-CUSTOMER-003 (exact frozen-snapshot field set beyond the approved
// minimum of destination name + address + Destination Source) and
// BDR-TASK-001 (mandatory business reference-number set) remain OPEN
// business decisions — see docs/CTO_SUMMARY_MVP_02.md. The snapshot column
// set below and the flexible TaskReference model are technical
// implementations constrained by the already-approved rules; neither
// resolves its BDR.
//
// `DeliveryTaskStatus` models the full 10-value conceptual Main Task Status
// lifecycle (Topic 04 §5) so the enum never needs a breaking alteration in
// a future milestone — only DRAFT and WAITING_PREPARATION are reachable
// through any API in MVP-02.

enum DeliveryTaskStatus {
  DRAFT
  WAITING_PREPARATION
  PREPARING
  READY_FOR_DISPATCH
  ASSIGNED
  IN_TRANSIT
  AT_DESTINATION
  WAITING_NEXT_ATTEMPT
  COMPLETED
  CANCELLED

  @@map("delivery_task_status")
}

enum DestinationSource {
  MASTER
  FREE_TEXT

  @@map("destination_source")
}

enum FreeTextFallbackReason {
  NO_SUITABLE_MASTER
  AD_HOC_DESTINATION

  @@map("free_text_fallback_reason")
}

/// Read-only Customer Master (BDR-CUSTOMER-001/002). No create/edit/delete
/// endpoint exists in MVP-02 — rows are inserted only by direct, manual,
/// operator-authorized database action, never by application code, a seed,
/// or a migration.
model Customer {
  id        String   @id @default(uuid()) @db.Uuid
  code      String?  @db.VarChar(64)
  name      String   @db.VarChar(255)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  destinations CustomerDestination[]
  tasks        DeliveryTask[]

  @@unique([code])
  @@index([name])
  @@map("customers")
}

/// Read-only Customer Destination Master (BDR-CUSTOMER-001/002). No
/// create/edit/delete endpoint exists in MVP-02.
model CustomerDestination {
  id                   String   @id @default(uuid()) @db.Uuid
  customerId           String   @map("customer_id") @db.Uuid
  code                 String?  @db.VarChar(64)
  destinationName      String   @map("destination_name") @db.VarChar(255)
  address              String   @db.Text
  contactName          String?  @map("contact_name") @db.VarChar(255)
  contactPhone         String?  @map("contact_phone") @db.VarChar(32)
  deliveryInstructions String?  @map("delivery_instructions") @db.Text
  locationReference    String?  @map("location_reference") @db.VarChar(255)
  accessNotes          String?  @map("access_notes") @db.Text
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // onDelete: Restrict — a Customer with any destination (Master or
  // referenced by a historical Task) must never be silently cascade-deleted.
  customer Customer       @relation(fields: [customerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  tasks    DeliveryTask[]

  @@index([customerId])
  @@index([destinationName])
  @@map("customer_destinations")
}

/// Server-verifiable evidence that a Customer Master search was performed
/// (§4.3) — required before any destination (MASTER or FREE_TEXT) may be
/// attached to a Task. Short-lived by design (`expiresAt`); never stores
/// secrets, tokens, cookies, or raw request data beyond the normalized
/// query text.
model CustomerMasterSearch {
  id                            String   @id @default(uuid()) @db.Uuid
  searchedByUserId              String   @map("searched_by_user_id") @db.Uuid
  normalizedQuery                String   @map("normalized_query") @db.VarChar(120)
  matchedCustomerDestinationIds String[] @map("matched_customer_destination_ids")
  resultCount                    Int      @map("result_count")
  searchedAt                     DateTime @default(now()) @map("searched_at") @db.Timestamptz(6)
  expiresAt                      DateTime @map("expires_at") @db.Timestamptz(6)

  searchedByUser User           @relation(fields: [searchedByUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  tasks          DeliveryTask[]

  @@index([searchedByUserId])
  @@index([expiresAt])
  @@map("customer_master_searches")
}

/// Delivery Task aggregate. DRAFT and WAITING_PREPARATION are the only
/// statuses reachable through any MVP-02 API (BR-TASK-007/BR-TASK-008).
/// `customerName` through `snapshotCreatedAt` are the Historical
/// Destination Snapshot (BR-TASK-009/BR-DATA-003) — immutable once the
/// Task leaves DRAFT because no endpoint accepts writes to a non-DRAFT
/// Task (see TasksService).
model DeliveryTask {
  id                  String              @id @default(uuid()) @db.Uuid
  taskNumber          String              @unique @map("task_number") @db.VarChar(32)
  status              DeliveryTaskStatus  @default(DRAFT)
  plannedDeliveryDate DateTime?           @map("planned_delivery_date") @db.Date
  createdByUserId     String              @map("created_by_user_id") @db.Uuid
  updatedByUserId     String              @map("updated_by_user_id") @db.Uuid
  submittedAt         DateTime?           @map("submitted_at") @db.Timestamptz(6)

  // Destination source + Historical Destination Snapshot. A CHECK
  // constraint (see migration SQL) enforces MASTER ⇢ customer/destination
  // set + no fallback reason, and FREE_TEXT ⇢ no customer/destination +
  // fallback reason required, at the database level as well as in the
  // application layer.
  destinationSource      DestinationSource       @map("destination_source")
  customerId             String?                 @map("customer_id") @db.Uuid
  customerDestinationId  String?                 @map("customer_destination_id") @db.Uuid
  customerSearchId       String                  @map("customer_search_id") @db.Uuid
  freeTextFallbackReason FreeTextFallbackReason? @map("free_text_fallback_reason")

  customerName            String   @map("customer_name") @db.VarChar(255)
  destinationName         String   @map("destination_name") @db.VarChar(255)
  address                 String   @db.Text
  contactName             String?  @map("contact_name") @db.VarChar(255)
  contactPhone            String?  @map("contact_phone") @db.VarChar(32)
  deliveryInstructions    String?  @map("delivery_instructions") @db.Text
  locationReference       String?  @map("location_reference") @db.VarChar(255)
  accessNotes             String?  @map("access_notes") @db.Text
  customerCodeSnapshot    String?  @map("customer_code_snapshot") @db.VarChar(64)
  destinationCodeSnapshot String?  @map("destination_code_snapshot") @db.VarChar(64)
  snapshotCreatedAt       DateTime @map("snapshot_created_at") @db.Timestamptz(6)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // onDelete: Restrict throughout — a Task, its snapshot, and its history
  // must remain traceable even if the referenced User/Customer/Destination
  // row is later deactivated (CLAUDE.md §6/§20).
  createdByUser  User                 @relation("DeliveryTaskCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  updatedByUser  User                 @relation("DeliveryTaskUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  customer       Customer?            @relation(fields: [customerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  destination    CustomerDestination? @relation(fields: [customerDestinationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  customerSearch CustomerMasterSearch @relation(fields: [customerSearchId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // onDelete: Cascade — items/references exist only as children of their own
  // Task (never shared, never independently meaningful) and there is no
  // Task-deletion endpoint in this milestone, so this only matters for local
  // test cleanup. TaskEvent is intentionally restricted below because it is
  // append-only audit/status history and must not be cascade-deleted.
  items      DeliveryTaskItem[]
  references TaskReference[]
  events     TaskEvent[]
  preparationRecord PreparationRecord?
  preparationDiscrepancyReports PreparationDiscrepancyReport[]
  preparationCorrections PreparationCorrectionRecord[]
  // MVP-04 — append-only assignment history plus the one-row-per-task
  // current-assignment pointer (see TaskCurrentAssignment doc comment).
  assignments       TaskAssignment[]
  currentAssignment TaskCurrentAssignment?

  @@index([status])
  @@index([plannedDeliveryDate])
  @@index([createdByUserId])
  @@index([customerSearchId])
  @@map("delivery_tasks")
}

/// Planned goods line (planned only — no stock deduction, no loaded/
/// delivered quantity, no serial/lot/barcode).
model DeliveryTaskItem {
  id              String   @id @default(uuid()) @db.Uuid
  taskId          String   @map("task_id") @db.Uuid
  lineNumber      Int      @map("line_number")
  description     String   @db.VarChar(500)
  plannedQuantity Decimal  @map("planned_quantity") @db.Decimal(18, 3)
  unit            String   @db.VarChar(32)
  notes           String?  @db.VarChar(500)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  task DeliveryTask @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  preparationItems PreparationItem[]

  @@unique([taskId, lineNumber])
  @@index([taskId])
  @@map("delivery_task_items")
}

/// Optional, flexible business-reference child record (BDR-TASK-001 —
/// OPEN). No reference type is mandatory in this milestone; the unique
/// constraint below only rejects an exact duplicate type/value pair on the
/// same Task.
model TaskReference {
  id             String   @id @default(uuid()) @db.Uuid
  taskId         String   @map("task_id") @db.Uuid
  referenceType  String   @map("reference_type") @db.VarChar(64)
  referenceValue String   @map("reference_value") @db.VarChar(128)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  task DeliveryTask @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([taskId, referenceType, referenceValue])
  @@index([taskId])
  @@map("task_references")
}

/// Append-only Task status-history entry — a row is never updated or
/// deleted, only created (CLAUDE.md §5 append-only history).
model TaskEvent {
  id             String              @id @default(uuid()) @db.Uuid
  taskId         String              @map("task_id") @db.Uuid
  eventType      String              @map("event_type") @db.VarChar(64)
  previousStatus DeliveryTaskStatus? @map("previous_status")
  newStatus      DeliveryTaskStatus  @map("new_status")
  actorUserId    String              @map("actor_user_id") @db.Uuid
  occurredAt     DateTime            @default(now()) @map("occurred_at") @db.Timestamptz(6)
  /// Safe, non-sensitive metadata only — never a password/token/hash or Prisma internals.
  metadata       Json?

  task      DeliveryTask @relation(fields: [taskId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  actorUser User         @relation(fields: [actorUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([taskId])
  @@map("task_events")
}

enum PreparationIssueStatus {
  OPEN
  RESOLVED

  @@map("preparation_issue_status")
}

enum PreparationEvidenceCategory {
  PRE_LOADING_PHOTO

  @@map("preparation_evidence_category")
}

enum PreparationCorrectionMateriality {
  NORMAL
  MATERIAL

  @@map("preparation_correction_materiality")
}

enum PreparationCorrectionReviewStatus {
  PENDING_REVIEW
  REVIEWED

  @@map("preparation_correction_review_status")
}

/// MVP-03 preparation header. One frozen preparation record per Task in
/// this milestone; future DeliveryAttempt records may reference this record
/// instead of copying evidence.
model PreparationRecord {
  id                     String    @id @default(uuid()) @db.Uuid
  taskId                 String    @unique @map("task_id") @db.Uuid
  startedByUserId        String    @map("started_by_user_id") @db.Uuid
  startedAt              DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  readyConfirmedByUserId String?   @map("ready_confirmed_by_user_id") @db.Uuid
  readyConfirmedAt       DateTime? @map("ready_confirmed_at") @db.Timestamptz(6)
  notes                  String?   @db.VarChar(1000)
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  task DeliveryTask @relation(fields: [taskId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  startedBy User @relation("PreparationStartedBy", fields: [startedByUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  readyConfirmedBy User? @relation("PreparationReadyConfirmedBy", fields: [readyConfirmedByUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  items PreparationItem[]
  issues PreparationIssue[]
  evidence PreparationEvidence[]
  discrepancyReports PreparationDiscrepancyReport[]
  corrections PreparationCorrectionRecord[]

  @@index([startedByUserId])
  @@index([readyConfirmedByUserId])
  @@map("preparation_records")
}

model PreparationItem {
  id                      String   @id @default(uuid()) @db.Uuid
  preparationId           String   @map("preparation_id") @db.Uuid
  taskItemId              String   @map("task_item_id") @db.Uuid
  lineNumber              Int      @map("line_number")
  descriptionSnapshot     String   @map("description_snapshot") @db.VarChar(500)
  plannedQuantitySnapshot Decimal  @map("planned_quantity_snapshot") @db.Decimal(18, 3)
  preparedQuantity        Decimal  @default(0) @map("prepared_quantity") @db.Decimal(18, 3)
  unitSnapshot            String   @map("unit_snapshot") @db.VarChar(32)
  notes                   String?  @db.VarChar(500)
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  preparation PreparationRecord @relation(fields: [preparationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  taskItem DeliveryTaskItem @relation(fields: [taskItemId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  issues PreparationIssue[]

  @@unique([preparationId, taskItemId])
  @@unique([preparationId, lineNumber])
  @@index([taskItemId])
  @@map("preparation_items")
}

model PreparationIssue {
  id                String                 @id @default(uuid()) @db.Uuid
  preparationId     String                 @map("preparation_id") @db.Uuid
  preparationItemId String?                @map("preparation_item_id") @db.Uuid
  description       String                 @db.VarChar(1000)
  status            PreparationIssueStatus @default(OPEN)
  reportedByUserId  String                 @map("reported_by_user_id") @db.Uuid
  reportedAt        DateTime               @default(now()) @map("reported_at") @db.Timestamptz(6)
  resolutionNote    String?                @map("resolution_note") @db.VarChar(1000)
  resolvedByUserId  String?                @map("resolved_by_user_id") @db.Uuid
  resolvedAt        DateTime?              @map("resolved_at") @db.Timestamptz(6)

  preparation PreparationRecord @relation(fields: [preparationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  preparationItem PreparationItem? @relation(fields: [preparationItemId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  reportedBy User @relation("PreparationIssueReportedBy", fields: [reportedByUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  resolvedBy User? @relation("PreparationIssueResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([preparationId, status])
  @@index([preparationItemId])
  @@index([reportedByUserId])
  @@index([resolvedByUserId])
  @@map("preparation_issues")
}

model PreparationEvidence {
  id               String                      @id @default(uuid()) @db.Uuid
  preparationId    String                      @map("preparation_id") @db.Uuid
  category         PreparationEvidenceCategory
  objectKey        String                      @unique @map("object_key") @db.VarChar(160)
  originalFilename String                      @map("original_filename") @db.VarChar(255)
  mediaType        String                      @map("media_type") @db.VarChar(64)
  sizeBytes        Int                         @map("size_bytes")
  sha256           String                      @db.VarChar(64)
  uploadedByUserId String                      @map("uploaded_by_user_id") @db.Uuid
  createdAt        DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)

  preparation PreparationRecord @relation(fields: [preparationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  uploadedBy User @relation(fields: [uploadedByUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([preparationId, category])
  @@index([uploadedByUserId])
  @@map("preparation_evidence")
}

model PreparationDiscrepancyReport {
  id                 String   @id @default(uuid()) @db.Uuid
  taskId             String   @map("task_id") @db.Uuid
  preparationId      String   @map("preparation_id") @db.Uuid
  reportedByUserId   String   @map("reported_by_user_id") @db.Uuid
  description        String   @db.VarChar(1000)
  reportedAt         DateTime @default(now()) @map("reported_at") @db.Timestamptz(6)
  linkedCorrectionId String?  @unique @map("linked_correction_id") @db.Uuid

  task DeliveryTask @relation(fields: [taskId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  preparation PreparationRecord @relation(fields: [preparationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  reportedBy User @relation(fields: [reportedByUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  linkedCorrection PreparationCorrectionRecord? @relation("LinkedPreparationCorrection", fields: [linkedCorrectionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  correctionRecords PreparationCorrectionRecord[] @relation("PreparationCorrectionDiscrepancyReport")

  @@index([taskId])
  @@index([preparationId])
  @@index([reportedByUserId])
  @@map("preparation_discrepancy_reports")
}

model PreparationCorrectionRecord {
  id                           String                              @id @default(uuid()) @db.Uuid
  taskId                       String                              @map("task_id") @db.Uuid
  preparationId                String                              @map("preparation_id") @db.Uuid
  discrepancyReportId          String?                             @map("discrepancy_report_id") @db.Uuid
  createdByUserId              String                              @map("created_by_user_id") @db.Uuid
  materiality                  PreparationCorrectionMateriality
  reason                       String                              @db.VarChar(1000)
  changeSummary                String                              @map("change_summary") @db.VarChar(1000)
  originalPreparationSnapshot  Json                                @map("original_preparation_snapshot")
  correctedOrExceptionSnapshot Json                                @map("corrected_or_exception_snapshot")
  reviewStatus                 PreparationCorrectionReviewStatus   @default(PENDING_REVIEW) @map("review_status")
  createdAt                    DateTime                            @default(now()) @map("created_at") @db.Timestamptz(6)
  reviewedByUserId             String?                             @map("reviewed_by_user_id") @db.Uuid
  reviewedAt                   DateTime?                           @map("reviewed_at") @db.Timestamptz(6)
  reviewNote                   String?                             @map("review_note") @db.VarChar(1000)

  task DeliveryTask @relation(fields: [taskId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  preparation PreparationRecord @relation(fields: [preparationId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  discrepancyReport PreparationDiscrepancyReport? @relation("PreparationCorrectionDiscrepancyReport", fields: [discrepancyReportId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  linkedFromDiscrepancy PreparationDiscrepancyReport? @relation("LinkedPreparationCorrection")
  createdBy User @relation("PreparationCorrectionCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  reviewedBy User? @relation("PreparationCorrectionReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([taskId])
  @@index([preparationId])
  @@index([discrepancyReportId])
  @@index([reviewStatus, materiality, createdAt])
  @@index([createdByUserId])
  @@index([reviewedByUserId])
  @@map("preparation_correction_records")
}

// ═══════════════════════════════════════════════════════════════════════
// MVP-04 — Delivery Task Assignment
// ═══════════════════════════════════════════════════════════════════════
//
// Traceability: BDR-ASSIGN-001 through BDR-ASSIGN-005 (approved — see
// docs/CTO_SUMMARY_MVP_04.md and Dispatch Knowledge Topic 07 §BDR-ASSIGN),
// BR-ASSIGN-001 through BR-ASSIGN-009, VR-ASSIGN-001a (Topic 06 §14).
//
// Three tables give the smallest robust model for "one current assignment,
// immutable history":
//   - TaskAssignment is an append-only event log — one immutable row per
//     initial assignment or reassignment, never updated after creation.
//   - TaskAssignmentSupport is the append-only supporting-employee child of
//     one TaskAssignment event, created once alongside it and never
//     modified afterward (BDR-ASSIGN-002 — informational only).
//   - TaskCurrentAssignment is a *mutable* one-row-per-task pointer at the
//     current TaskAssignment. It is the only mutated row in this schema
//     (its `currentAssignmentId` is repointed on reassignment) — history
//     rows in TaskAssignment/TaskAssignmentSupport are never touched. Its
//     primary key on `taskId` is the database-level backstop for "at most
//     one current assignment per task" (§8/§15 of the MVP-04 brief),
//     independent of and in addition to the PostgreSQL row lock every
//     assignment/reassignment transaction takes on `delivery_tasks` first.
//
// Cross-entity invariants Postgres cannot express as a single-table CHECK
// (primary assignee must not also appear as a supporting employee; primary
// assignee / supporting employees must be active users currently holding
// INTERNAL_DELIVERY_EMPLOYEE) are enforced in the locked application
// transaction (AssignmentService) — a database trigger was judged
// unnecessary complexity for this milestone's scope.
//
// No display-name snapshot is stored: no User-profile-edit endpoint exists
// anywhere in the system yet, so a live join to `users.display_name` is
// exactly as accurate as a snapshot would be, without the duplication.

enum AssignmentType {
  INITIAL
  REASSIGNMENT

  @@map("assignment_type")
}

/// Append-only assignment/reassignment event log (BR-ASSIGN-004 — history
/// must never be overwritten). `previousAssignmentId` is null for the
/// INITIAL event and points at the exact TaskAssignment a REASSIGNMENT
/// superseded, so the full chain is reconstructable. `note` is populated
/// only for INITIAL; `reason` is mandatory and non-blank only for
/// REASSIGNMENT (BDR-ASSIGN-005) — enforced by
/// `task_assignments_type_consistency_check` at the database level.
model TaskAssignment {
  id                    String         @id @default(uuid()) @db.Uuid
  taskId                String         @map("task_id") @db.Uuid
  assignmentType        AssignmentType @map("assignment_type")
  previousAssignmentId  String?        @unique @map("previous_assignment_id") @db.Uuid
  primaryAssigneeUserId String         @map("primary_assignee_user_id") @db.Uuid
  actorUserId           String         @map("actor_user_id") @db.Uuid
  note                  String?        @db.VarChar(1000)
  reason                String?        @db.VarChar(1000)
  createdAt             DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  task               DeliveryTask            @relation(fields: [taskId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  previousAssignment TaskAssignment?         @relation("AssignmentSupersession", fields: [previousAssignmentId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  supersededBy       TaskAssignment?         @relation("AssignmentSupersession")
  primaryAssignee    User                    @relation("TaskAssignmentPrimary", fields: [primaryAssigneeUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  actor              User                    @relation("TaskAssignmentActor", fields: [actorUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  supportingEmployees TaskAssignmentSupport[]
  currentPointer      TaskCurrentAssignment?

  @@index([taskId])
  @@index([primaryAssigneeUserId])
  @@index([actorUserId])
  @@map("task_assignments")
}

/// Supporting employees of one immutable TaskAssignment event
/// (BDR-ASSIGN-001/002 — informational only, never task record scope).
/// Created once alongside its parent TaskAssignment and never modified.
model TaskAssignmentSupport {
  id            String   @id @default(uuid()) @db.Uuid
  assignmentId  String   @map("assignment_id") @db.Uuid
  supportUserId String   @map("support_user_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  assignment  TaskAssignment @relation(fields: [assignmentId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  supportUser User           @relation(fields: [supportUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([assignmentId, supportUserId])
  @@index([assignmentId])
  @@index([supportUserId])
  @@map("task_assignment_supports")
}

/// Mutable one-row-per-task pointer at the current TaskAssignment. The
/// primary key on `taskId` is the database-level "at most one current
/// assignment per task" backstop. `primaryAssigneeUserId` is a denormalized
/// copy of `currentAssignment.primaryAssigneeUserId` maintained only by
/// AssignmentService (both are always written in the same transaction) so
/// active-workload-by-primary-assignee queries never need to join through
/// TaskAssignment.
model TaskCurrentAssignment {
  taskId                String   @id @map("task_id") @db.Uuid
  currentAssignmentId   String   @unique @map("current_assignment_id") @db.Uuid
  primaryAssigneeUserId String   @map("primary_assignee_user_id") @db.Uuid
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  task              DeliveryTask   @relation(fields: [taskId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  currentAssignment TaskAssignment @relation(fields: [currentAssignmentId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  primaryAssignee   User           @relation("TaskCurrentAssignmentPrimary", fields: [primaryAssigneeUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([primaryAssigneeUserId])
  @@map("task_current_assignments")
}
